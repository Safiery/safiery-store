# Copy to .env (for `netlify dev`) or set these in Netlify -> Site settings -> Environment variables.

# Stripe secret key - get your key from the Stripe dashboard (test mode for development).
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# Stripe webhook signing secret - from the Stripe Dashboard webhook endpoint pointed at
# /.netlify/functions/stripe-webhook (event: checkout.session.completed). Required for
# orders to flow into the ERP.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Quasar HQ (ERP) origin - used by checkout (authoritative B2B pricing), the order push,
# and the AI assistant's lead capture.
ERP_BASE_URL=https://quasar-safiery-967.netlify.app

# Shared secret for server-to-server calls store -> ERP (store-order-ingest, store-lead).
# Must EXACTLY match STORE_SHARED_SECRET set on the Quasar HQ Netlify site.
STORE_SHARED_SECRET=set_a_long_random_secret_here

# Anthropic API key for the store's AI assistant (product Q&A + lead capture).
ANTHROPIC_API_KEY=sk-ant-your_key_here
# Optional model override for the assistant (defaults to a current Claude model).
# STORE_ASSISTANT_MODEL=claude-sonnet-4-6

# Optional - Netlify sets URL automatically in deploys. For local dev it defaults to the dev host.
# URL=http://localhost:8888
